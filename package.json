{
  "name": "edgelord",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @edgelord/api dev",
    "dev:web": "pnpm --filter @edgelord/web dev",
    "test": "pnpm --recursive test",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint",
    "verify": "pnpm test && pnpm typecheck && pnpm --filter @edgelord/web build",
    "acceptance:minimal-labeler": "node scripts/minimal-labeler-workflow.mjs --acceptance",
    "closeout:minimal-labeler": "node scripts/minimal-labeler-workflow.mjs --closeout",
    "data:coverage": "node scripts/data-coverage.mjs --write",
    "export:backup": "node scripts/export-backup.mjs",
    "research:report": "node scripts/research-report.mjs",
    "workflow:minimal-labeler": "node scripts/minimal-labeler-workflow.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
