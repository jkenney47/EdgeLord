{
  "version": "edgelord.pine_feature_map.v1",
  "expressions": {
    "feature_close": "close",
    "feature_volume": "volume",
    "feature_ema25": "ta.ema(close, 25)",
    "feature_sma100": "ta.sma(close, 100)",
    "feature_atr14": "ta.atr(14)",
    "feature_stoch_rsi_k": "ta.sma(ta.stoch(ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), 15), 7)",
    "feature_stoch_rsi_d": "ta.sma(ta.sma(ta.stoch(ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), ta.rsi(ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10), 14), 15), 7), 10)",
    "feature_close_above_ema25": "close > ta.ema(close, 25)",
    "feature_close_above_sma100": "close > ta.sma(close, 100)",
    "feature_distance_to_ema25_pct": "((close - ta.ema(close, 25)) / ta.ema(close, 25)) * 100",
    "feature_distance_to_sma100_pct": "((close - ta.sma(close, 100)) / ta.sma(close, 100)) * 100",
    "feature_recent_5_return_pct": "((close - close[5]) / close[5]) * 100",
    "feature_recent_10_return_pct": "((close - close[10]) / close[10]) * 100",
    "feature_recent_20_return_pct": "((close - close[20]) / close[20]) * 100",
    "feature_recent_20_high": "ta.highest(high, 20)",
    "feature_recent_20_low": "ta.lowest(low, 20)",
    "feature_close_rank_recent_20": "((close - ta.lowest(low, 20)) / math.max(ta.highest(high, 20) - ta.lowest(low, 20), syminfo.mintick))",
    "feature_wvf": "((ta.highest(close, 22) - low) / ta.highest(close, 22)) * 100",
    "feature_wvf_midline": "ta.sma(((ta.highest(close, 22) - low) / ta.highest(close, 22)) * 100, 20)",
    "feature_wvf_upper_band": "ta.sma(((ta.highest(close, 22) - low) / ta.highest(close, 22)) * 100, 20) + 2 * ta.stdev(((ta.highest(close, 22) - low) / ta.highest(close, 22)) * 100, 20)",
    "feature_wvf_range_high": "ta.highest(((ta.highest(close, 22) - low) / ta.highest(close, 22)) * 100, 50) * 0.85",
    "feature_smio_smi": "ta.tsi(close, 20, 20)",
    "feature_smio_signal": "ta.ema(ta.tsi(close, 20, 20), 10)",
    "feature_smio_oscillator": "ta.tsi(close, 20, 20) - ta.ema(ta.tsi(close, 20, 20), 10)",
    "feature_vwap": "ta.vwap(hlc3, timeframe.change(\"M\"))",
    "feature_vwap_upper_band_1": "ta.vwap(hlc3, timeframe.change(\"M\")) + (ta.vwap(hlc3, timeframe.change(\"M\"), 1)[1] - ta.vwap(hlc3, timeframe.change(\"M\")))",
    "feature_vwap_lower_band_1": "ta.vwap(hlc3, timeframe.change(\"M\")) - (ta.vwap(hlc3, timeframe.change(\"M\"), 1)[1] - ta.vwap(hlc3, timeframe.change(\"M\")))",
    "feature_distance_to_vwap_pct": "((close - ta.vwap(hlc3, timeframe.change(\"M\"))) / ta.vwap(hlc3, timeframe.change(\"M\"))) * 100"
  }
}
